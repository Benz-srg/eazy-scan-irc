# ---- LLM analysis provider ----
# Which engine analyzes the transcript. Default "claude-cli" needs NO API key.
#   claude-cli : local Claude Code CLI (host login)  — see README "เชื่อม Claude Code CLI"
#   anthropic  : Anthropic API   (ANTHROPIC_API_KEY)
#   gemini     : Google Gemini   (GEMINI_API_KEY)
#   openai     : OpenAI API       (OPENAI_API_KEY)  — used by Docker by default
LLM_PROVIDER=claude-cli

# Claude CLI options (when LLM_PROVIDER=claude-cli). FAST=Haiku, DEEP=Sonnet.
CLAUDE_CLI_PATH=claude
CLAUDE_CLI_FAST_MODEL=claude-haiku-4-5-20251001
CLAUDE_CLI_DEEP_MODEL=claude-sonnet-4-6
CLAUDE_CLI_TIMEOUT_MS=180000

# ---- API-key LLM providers (used when LLM_PROVIDER is set to one of these) ----
ANTHROPIC_API_KEY=
# ANTHROPIC_ANALYSIS_MODEL=        # override; else fast→haiku / deep→sonnet
GEMINI_API_KEY=
# GEMINI_ANALYSIS_MODEL=           # override; else fast→gemini-2.5-flash / deep→gemini-2.5-pro

# ---- OpenAI (Whisper STT, and analysis if LLM_PROVIDER=openai) ----
# Optional: users can also paste their own OpenAI key in the app (browser-only).
# Without any key + without local Whisper, analyze falls back to the bundled
# sample so the UI is always demoable.
OPENAI_API_KEY=
OPENAI_STT_MODEL=whisper-1
# OPENAI_ANALYSIS_MODEL=           # override; else fast→gpt-4o-mini / deep→gpt-4o

# ---- Local Whisper (Python FastAPI) ----
# URL of the local transcription service (python/main.py). Used when the user
# selects the "Local Whisper" provider. Leave blank to disable local STT.
PYTHON_WHISPER_URL=http://localhost:8000
# Whisper model size. Thai accuracy vs. speed on Mac CPU (~15s clip, measured):
#   small=55s/poor · medium=156s/poor · large-v3=280s/excellent
# large-v3 is the only local model with good Thai, but it is slow on CPU.
# For fast + accurate Thai, prefer the OpenAI Whisper provider in the UI.
WHISPER_MODEL=large-v3
# Thai-bias prompt: stops Whisper from code-switching Thai words to English
# (e.g. "หมูปิ้ง" -> "Moving"). Override to add your own domain vocabulary.
# WHISPER_INITIAL_PROMPT=

# ---- Database (MongoDB via Prisma) ----
# Optional. Without it, history persists in the browser only (localStorage).
# Local Docker (see docker-compose.yml — single-node replica set rs0):
#   docker compose up -d && pnpm db:push
DATABASE_URL=mongodb://localhost:27017/eazyscan?replicaSet=rs0&directConnection=true
# Hosted example:
#   mongodb+srv://user:pass@cluster.mongodb.net/eazyscan?retryWrites=true&w=majority
