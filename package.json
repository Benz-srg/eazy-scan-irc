{
  "name": "eazyscan",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "dev": "next dev",
    "dev:all": "concurrently -n web,whisper -c blue,magenta \"next dev\" \"pnpm whisper\"",
    "whisper": "cd python && ./.venv/bin/uvicorn main:app --port 8000",
    "whisper:setup": "cd python && PY=$(command -v python3.12 || command -v python3.11 || command -v python3) && echo \"using $PY\" && \"$PY\" -m venv .venv && ./.venv/bin/pip install -U pip && ./.venv/bin/pip install -r requirements.txt",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:up": "docker compose up -d mongo",
    "docker": "docker compose up --build",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@ai-sdk/google": "^3.0.80",
    "@ai-sdk/openai": "^3.0.67",
    "@pdf-lib/fontkit": "^1.1.1",
    "@prisma/client": "^6.19.3",
    "ai": "^6.0.194",
    "docx": "^9.7.1",
    "jotai": "^2.20.0",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "next": "16.2.7",
    "openai": "^6.41.0",
    "pdf-lib": "^1.17.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "jsdom": "^29.1.1",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
